# Application
SECRET_KEY_BASE=generate-with-mix-phx-gen-secret-min-64-chars
DATABASE_PATH=/app/data/skillset_evaluator.db
PHX_HOST=localhost
PORT=4000

# Microsoft OAuth (optional for local development)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# Default admin (seeded on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# AI Chat — LLM Provider (optional, enables chat feature)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_MODEL=claude-sonnet-4-20250514
LLM_PROVIDER=anthropic

# MiniMax (optional, Chinese language fallback)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1/text/chatcompletion_v2
MINIMAX_GROUP_ID=
